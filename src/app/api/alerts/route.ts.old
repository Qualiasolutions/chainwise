import { NextRequest, NextResponse } from 'next/server'
import { auth } from '@/auth'
import { prisma } from '@/lib/db'
import { z } from 'zod'
import { createProtectedRoute } from '@/lib/middleware/auth'
import { PermissionChecker } from '@/lib/permissions'
import { Decimal } from '@prisma/client/runtime/library'

// Request validation schemas
const createAlertSchema = z.object({
  cryptoId: z.string().min(1),
  alertType: z.enum(['price_above', 'price_below', 'volume_spike', 'percentage_change', 'market_cap_change']),
  targetValue: z.number().positive(),
  isActive: z.boolean().default(true)
})

const updateAlertSchema = createAlertSchema.partial().extend({
  id: z.string()
})

const querySchema = z.object({
  active: z.string().optional().transform(val => val === 'true'),
  cryptoId: z.string().optional(),
  limit: z.string().optional().transform(val => parseInt(val || '50')),
  offset: z.string().optional().transform(val => parseInt(val || '0'))
})

// GET /api/alerts - Get user alerts
export const GET = createProtectedRoute(
  async (request): Promise<NextResponse<any>> => {
    try {
      const { searchParams } = new URL(request.url)
      const { active, cryptoId, limit, offset } = querySchema.parse(Object.fromEntries(searchParams))
      const userId = request.user.id

      const where: any = {
        userId
      }

      if (active !== undefined) {
        where.isActive = active
      }

      if (cryptoId) {
        where.cryptoId = cryptoId
      }

      const alerts = await prisma.userAlert.findMany({
        where,
        orderBy: { createdAt: 'desc' },
        take: limit,
        skip: offset
      })

      // Get total count for pagination
      const totalCount = await prisma.userAlert.count({ where })

      return NextResponse.json({
        alerts,
        pagination: {
          total: totalCount,
          limit,
          offset,
          hasMore: offset + limit < totalCount
        }
      })

    } catch (error) {
      console.error('Error fetching alerts:', error)

      if (error instanceof z.ZodError) {
        return NextResponse.json({
          error: 'Invalid query parameters',
          details: error.errors
        }, { status: 400 })
      }

      return NextResponse.json({
        error: 'Failed to fetch alerts'
      }, { status: 500 })
    }
  },
  { feature: 'alerts_basic' }
)

// POST /api/alerts - Create new alert
export const POST = createProtectedRoute(
  async (request): Promise<NextResponse<any>> => {
    try {
      const body = await request.json()
      const validatedData = createAlertSchema.parse(body)
      const userId = request.user.id

      // Check if user can create more alerts
      const canCreate = await PermissionChecker.canCreateAlert(userId)
      if (!canCreate) {
        const { permissions, usage } = await PermissionChecker.checkUserPermissions(userId)
        return NextResponse.json({
          error: 'Alert limit reached',
          message: `Your ${request.user.subscriptionTier} plan allows up to ${permissions.maxAlerts} alerts. You currently have ${usage.alerts}.`,
          currentCount: usage.alerts,
          maxAllowed: permissions.maxAlerts,
          upgradeRequired: true
        }, { status: 403 })
      }

      const alert = await prisma.userAlert.create({
        data: {
          userId,
          cryptoId: validatedData.cryptoId,
          alertType: validatedData.alertType,
          targetValue: new Decimal(validatedData.targetValue),
          isActive: validatedData.isActive
        }
      })

      // Log activity
      await prisma.userActivityLog.create({
        data: {
          userId,
          action: 'alert_created',
          entityType: 'alert',
          entityId: alert.id,
          metadata: {
            cryptoId: validatedData.cryptoId,
            alertType: validatedData.alertType,
            targetValue: validatedData.targetValue
          }
        }
      })

      return NextResponse.json(alert, { status: 201 })

    } catch (error) {
      console.error('Error creating alert:', error)

      if (error instanceof z.ZodError) {
        return NextResponse.json({
          error: 'Invalid alert data',
          details: error.errors
        }, { status: 400 })
      }

      return NextResponse.json({
        error: 'Failed to create alert'
      }, { status: 500 })
    }
  },
  { feature: 'alerts_basic' }
)

// PUT /api/alerts - Update alert
export async function PUT(request: NextRequest) {
  try {
    const session = await auth()
    if (!session?.user?.id) {
      return NextResponse.json({ error: 'Unauthorized' }, { status: 401 })
    }

    const body = await request.json()
    const validatedData = updateAlertSchema.parse(body)
    const userId = session.user.id

    // Verify alert ownership
    const existingAlert = await prisma.userAlert.findFirst({
      where: {
        id: validatedData.id,
        userId
      }
    })

    if (!existingAlert) {
      return NextResponse.json({ error: 'Alert not found' }, { status: 404 })
    }

    const updatedAlert = await prisma.userAlert.update({
      where: { id: validatedData.id },
      data: {
        ...(validatedData.cryptoId && { cryptoId: validatedData.cryptoId }),
        ...(validatedData.alertType && { alertType: validatedData.alertType }),
        ...(validatedData.targetValue && { targetValue: new Decimal(validatedData.targetValue) }),
        ...(validatedData.isActive !== undefined && { isActive: validatedData.isActive })
      }
    })

    // Log activity
    await prisma.userActivityLog.create({
      data: {
        userId,
        action: 'alert_updated',
        entityType: 'alert',
        entityId: updatedAlert.id,
        metadata: {
          changes: Object.keys(validatedData).filter(key => key !== 'id')
        }
      }
    })

    return NextResponse.json(updatedAlert)

  } catch (error) {
    console.error('Error updating alert:', error)

    if (error instanceof z.ZodError) {
      return NextResponse.json({
        error: 'Invalid alert data',
        details: error.errors
      }, { status: 400 })
    }

    return NextResponse.json({
      error: 'Failed to update alert'
    }, { status: 500 })
  }
}

// DELETE /api/alerts/[id] - Delete alert
export async function DELETE(request: NextRequest) {
  try {
    const session = await auth()
    if (!session?.user?.id) {
      return NextResponse.json({ error: 'Unauthorized' }, { status: 401 })
    }

    const { searchParams } = new URL(request.url)
    const alertId = searchParams.get('id')

    if (!alertId) {
      return NextResponse.json({ error: 'Alert ID required' }, { status: 400 })
    }

    // Verify alert ownership and delete
    const alert = await prisma.userAlert.deleteMany({
      where: {
        id: alertId,
        userId: session.user.id
      }
    })

    if (alert.count === 0) {
      return NextResponse.json({ error: 'Alert not found' }, { status: 404 })
    }

    // Log activity
    await prisma.userActivityLog.create({
      data: {
        userId: session.user.id,
        action: 'alert_deleted',
        entityType: 'alert',
        entityId: alertId
      }
    })

    return NextResponse.json({ success: true })

  } catch (error) {
    console.error('Error deleting alert:', error)
    return NextResponse.json({
      error: 'Failed to delete alert'
    }, { status: 500 })
  }
}
